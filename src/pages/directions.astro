---
import Layout from "../layouts/Layout.astro";
import PageCard from "../components/PageCard.astro";
---

<Layout>
    <PageCard title="Directions" subtitle="How to get to the party">
        <div class="directions-content">
            <div class="venues-container">
                <div class="venue-row">
                    <div class="venue-label">
                        <h2>Ceremony - 4pm</h2>
                        <h3>Prelude Concert - 3:30pm</h3>
                    </div>
                    <div class="venue-details">
                        <h3>First Church in Marlborough</h3>
                        <p>37 High St<br />Marlborough, MA 01752</p>
                    </div>
                </div>
            </div>

            <div class="map-container">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2948.7154697305587!2d-71.54788202357078!3d42.34858927119402!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e38b689b278803%3A0x3666b7da02003876!2sFirst%20Church%20Marlborough!5e0!3m2!1sen!2sus!4v1780449076696!5m2!1sen!2sus"
                    width="100%"
                    height="500px"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer"></iframe>
            </div>

            <div class="instructions">
                <h3>Parking at First Church</h3>
                <p>
                    Please park in the lot at the rear of the church.
                    The entrance can be found on Bolton St.
                </p>
            </div>

            <div class="venues-container">
                <div class="venue-row">
                    <div class="venue-label">
                        <h2>Reception - 5pm</h2>
                    </div>
                    <div class="venue-details">
                        <h3>Sanctuary</h3>
                        <p>82 Main St<br />Maynard, MA 01754</p>
                    </div>
                </div>
            </div>

            <div class="map-container">
                <iframe
                    src="https://www.google.com/maps/d/embed?mid=1Q-b2L77amn_zqGvtE-DsMVexZrcfrJI&ehbc=2E312F&noprof=1"
                    width="100%"
                    height="500px"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer"></iframe>
            </div>

            <div class="instructions">
                <h3>Parking at Sanctuary</h3>
                <p>
                    Free parking can be found in lots on Walnut St., River St., and off of Main St. 
                    There is no parking next to the actual venue, so please plan to park in one of these lots.
                    Click on the sidebar in the map above to see a list of the lots (marked in blue).    
                    All lots are within walking distance of the venue.
                </p>
            </div>
        </div>
    </PageCard>
</Layout>

<style>
    .directions-content {
        width: 100%;
    }

    .venues-container {
        max-width: 600px;
        margin: 0 auto 3rem auto;
        background: var(--bg-primary); /* Beige contrasting card */
        border-radius: 12px;
        padding: 2.5rem 2.5rem;
        border: 2px solid var(--accent-sage);
        box-shadow: 0 10px 25px rgba(42, 46, 41, 0.05);
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .venue-row {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        text-align: center;
        border-bottom: 1px solid var(--accent-sage);
        padding-bottom: 1.5rem;
    }

    .venue-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .venue-label {
        text-align: center;
    }

    .venue-label h2 {
        font-family: var(--font-display);
        font-size: 2.2rem;
        color: var(--text-dark);
        margin: 0;
    }

    .venue-label h3 {
        margin: 0.5rem 0 0 0;
    }

    .venue-details {
        text-align: center;
    }

    .venue-details h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        color: var(--text-dark);
        margin: 0 0 0.5rem 0;
    }

    .venue-details p {
        font-family: var(--font-body);
        color: var(--text-muted);
        font-size: 1.1rem;
        line-height: 1.5;
        margin: 0;
    }

    .map-container {
        margin: 3rem 0;
        width: 100%;
        height: 500px;
        background-color: var(--bg-primary);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--accent-sage);
        box-shadow: 0 10px 25px rgba(42, 46, 41, 0.03);
    }

    .instructions {
        max-width: 500px;
        margin: 0 auto 4rem auto;
        text-align: center;
        background: var(--bg-card); /* White, less contrasting */
        border-radius: 10px;
        padding: 1.5rem 2rem;
        border: 1px solid var(--accent-sage); /* Thinner border */
    }

    .instructions:empty {
        display: none;
    }

    .instructions h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        color: var(--text-dark);
        margin-top: 0;
        margin-bottom: 0.5rem;
    }

    .instructions p {
        font-family: var(--font-body);
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 0;
        font-size: 1rem;
    }
</style>