---
import Layout from '../layouts/Layout.astro';
import PageCard from '../components/PageCard.astro';
import FAQCard from '../components/FAQCard.astro';
---

<Layout>
  <PageCard title="FAQs" subtitle="Everything you need to know">
    <div class="faq-accordion">
      <FAQCard 
        question="What is the dress code?" 
        answer="We kindly request formal attire. For men, this means a suit and tie. For women, an elegant cocktail dress or full-length gown is perfect." 
      />

      <FAQCard 
        question="Are children invited?" 
        answer="While we love your little ones, our wedding is an adults-only event so that everyone can relax and enjoy the evening." 
      />

      <FAQCard 
        question="Is there a hotel block?" 
        answer="Yes, we have reserved a block of rooms at the nearby Grand Hotel. Please mention our names when booking to receive the discounted rate." 
      />

      <FAQCard 
        question="Will the ceremony be indoors or outdoors?" 
        answer="Weather permitting, the ceremony will take place outdoors in the garden. The reception will be held indoors." 
      />
    </div>
  </PageCard>
</Layout>

<style>
  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
