---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  role?: string;
  image: ImageMetadata;
}

const { name, role, image } = Astro.props;
---

<div class="party-member">
  <div class="portrait-container">
    <Image 
      src={image} 
      alt={name} 
      class="portrait-image" 
      width={400} 
      height={400} 
      quality="max" 
      densities={[1.5, 2]} 
      format="webp" 
    />
  </div>
  <div class="member-info">
    <h2>{name}</h2>
    {role && <p class="role">{role}</p>}
  </div>
</div>

<style>
  .party-member {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
    background: var(--bg-card);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--accent-sage);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    min-width: 0;
  }

  .party-member:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(42,46,41,0.05);
  }

  .portrait-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    border: 1px solid var(--accent-sage);
    overflow: hidden;
    background-color: var(--bg-primary);
  }

  .portrait-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-info h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--text-dark);
    margin: 0;
  }

  .role {
    font-family: var(--font-body);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0.3rem 0 0 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
</style>
