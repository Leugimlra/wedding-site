---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  role: string;
  blurb: string;
  image: ImageMetadata;
  reverse?: boolean;
}

const { name, role, blurb, image, reverse = false } = Astro.props;
---

<div class={`party-member ${reverse ? 'reverse' : ''}`}>
  <div class="portrait-container">
    <Image 
      src={image} 
      alt={name} 
      class="portrait-image" 
      width={240} 
      height={240} 
      quality="max" 
      densities={[1.5, 2]} 
      format="webp" 
    />
  </div>
  <div class="member-info">
    <h2>{name}</h2>
    <p class="role">{role}</p>
    <p class="blurb">{blurb}</p>
  </div>
</div>

<style>
  .party-member {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: var(--bg-card);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--accent-sage);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .party-member:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(42,46,41,0.05);
  }

  .party-member.reverse {
    flex-direction: row-reverse;
  }

  .portrait-container {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px solid var(--accent-sage);
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--bg-primary);
  }

  .portrait-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .member-info h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--text-dark);
    margin: 0 0 0.2rem 0;
  }

  .role {
    font-family: var(--font-body);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .blurb {
    font-family: var(--font-body);
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .party-member, .party-member.reverse {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
