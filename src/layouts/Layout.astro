---
import Header from '../components/Header.astro';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Timothy and Miguel</title>
		
		<!-- Google Fonts for premium typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bellefair&display=swap" rel="stylesheet">
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
    @font-face {
        font-family: 'TAN Mon Cheri';
        src: url('/fonts/TAN-MONCHERI.woff2') format('woff2'),
             url('/fonts/TAN-MONCHERI.woff') format('woff');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
    }

	:root {
		--bg-primary: #EFECE5; /* Light warm beige */
		--bg-card: #FCFBF9; /* Nearly white for contrast */
		--accent-sage: #D2D9CC; /* Muted sage green from the image blob */
		--text-dark: #2b2b2b; /* Dark text */
		--text-muted: #2b2b2b; /* Muted dark text */
		--font-body: 'Bellefair', serif;
		--font-display: 'TAN Mon Cheri', serif;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: var(--bg-primary);
		color: var(--text-dark);
		font-family: var(--font-body);
	}
	*, *::before, *::after {
		box-sizing: border-box;
	}
	h1, h2, h3, h4, h5, h6, .title {
		font-family: var(--font-display);
		font-weight: normal;
	}
	main {
		min-height: calc(100vh - 80px); /* Adjust based on header height */
	}
</style>
